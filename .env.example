# XRPFi Verifiable Copilot — environment variables
# Copy to .env and fill in values for your environment

# Google AI (required for agent reasoning)
GOOGLE_API_KEY=your_google_api_key_here

# Flare networks (defaults are testnets — safe)
FLARE_RPC_URL=https://coston2-api.flare.network/ext/C/rpc
SONGBIRD_RPC_URL=https://songbird-api.flare.network/ext/C/rpc

# Ethereum (for ENS resolution)
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
ETH_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# 0G storage (mainnet — Chain ID 16661)
ZERO_G_STORAGE_URL=https://indexer-storage-turbo.0g.ai
ZERO_G_RPC_URL=https://0g-rpc.publicnode.com
ZERO_G_CHAIN_ID=16661
ZERO_G_FLOW_CONTRACT=0x62D4144dB0F0a6fBBaeb6296c785C71B3D57C526
ZERO_G_EXPLORER=https://chainscan.0g.ai
ZERO_G_PRIVATE_KEY=  # funded 0G key for real storage upload

# Uniswap
UNISWAP_API_URL=https://api.uniswap.org/v2
UNISWAP_API_KEY=  # optional depending on endpoint

# Gensyn AXL (local dev defaults)
AXL_NODE_A_ENDPOINT=http://localhost:8765
AXL_NODE_B_ENDPOINT=http://localhost:8766

# Agent signing key (TESTNET ONLY)
AGENT_PRIVATE_KEY=  # testnet private key for demo transactions
